&CONTROL
  calculation = 'bands',
  prefix      = 'PdSe2_wann',
  outdir = "../tmp/",
  pseudo_dir = "../pseudo/",
  verbosity   = 'high',
  tprnfor = .true.,
  tstress = .true.,
  restart_mode = 'from_scratch'
/

&SYSTEM
   ntyp             = 2,
   nat              = 6,
   ibrav            = 0,
   ecutwfc = 80,
   ecutrho = 800,
   occupations = 'smearing',
   smearing = 'mv',
   degauss = 0.02,
   noncolin = .true.,
   lspinorb = .true.,
   nbnd = 96,


/
&ELECTRONS
   conv_thr = 1.0d-8,
   mixing_beta = 0.3,
   electron_maxstep = 200,
/

