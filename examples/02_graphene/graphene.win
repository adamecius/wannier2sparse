! Minimal Wannier model for graphene: 2 pz orbitals -> pi / pi* bands
num_wann  = 2
num_bands = 16

begin projections
C:pz
end projections

! ---- disentanglement windows (absolute eV; E_F = -1.7683 eV) ----
! The pi/pi* manifold is entangled with sigma below and band6 above, so no
! window brackets it whole. Outer window is generous; disentanglement uses
! the pz projections to extract the pi-character subspace across crossings.
dis_win_min  = -12.0
dis_win_max  =   6.0
! frozen window: the clean energy gap where pi/pi* are the ONLY bands on the
! 12x12 grid -- sigma tops at -4.82 eV, band6 bottoms at +2.30 eV. Pinning
! this region forces the correct pz subspace near E_F (incl. Dirac point).
! dis_froz_min = -4.70
! dis_froz_max =  2.20

dis_num_iter = 1000
num_iter     = 1000
dis_mix_ratio = 0.5

guiding_centres = true

site_symmetry = true
symmetrize_eps = 1.0e-8

write_hr   = true
write_xyz  = true
bands_plot = true
bands_num_points = 100

fermi_energy = -1.7683

mp_grid = 12 12 1

begin kpoint_path
G  0.0000000  0.0000000  0.0000000   M  0.5000000  0.0000000  0.0000000
M  0.5000000  0.0000000  0.0000000   K  0.3333333  0.3333333  0.0000000
K  0.3333333  0.3333333  0.0000000   G  0.0000000  0.0000000  0.0000000
end kpoint_path

begin unit_cell_cart
ang
   2.4672312604   0.0000000000   0.0000000000
  -1.2336156302   2.1366849485   0.0000000000
   0.0000000000   0.0000000000  15.0000000000
end unit_cell_cart

begin atoms_frac
C   0.6666666667   0.3333333333   0.5000000000
C   0.3333333333   0.6666666667   0.5000000000
end atoms_frac

