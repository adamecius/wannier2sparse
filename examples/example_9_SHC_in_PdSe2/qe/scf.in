&CONTROL
  calculation = 'scf',
  prefix      = 'PdSe2_wann',
  outdir      = "../tmp/",
  pseudo_dir  = "../pseudo/",
  verbosity   = 'high',
  tprnfor = .true.,
  tstress = .true.,
/

&SYSTEM
   ntyp             = 2,
   nat              = 6,
   ibrav            = 0,
   ecutwfc = 80,
   ecutrho = 800,
   occupations = 'smearing',
   smearing = 'mv',
   degauss = 0.02,
   noncolin = .true.,
   lspinorb = .true.,


/
&ELECTRONS
   conv_thr = 1.0d-8,
   mixing_beta = 0.3,
   electron_maxstep = 200,
/

